# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored, so your actual secrets never get committed.

# --- PostgreSQL memory database ---
# Stores the projects you work in, full conversation history, and per-project memory.
# See the "Projects & memory (Postgres)" section in README.md for how to install a
# server and create the database. Replace YOUR_PASSWORD with your postgres password.
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/openrouter_agent

# --- OpenRouter API key ---
# Get one at https://openrouter.ai/keys
# Optional here — you can also paste it into the web UI Settings panel instead.
OPENROUTER_API_KEY=

# --- NVIDIA build API key (nvidia/… models) ---
# Get one at https://build.nvidia.com/ . Optional — you can paste it into Settings instead.
NVIDIA_API_KEY=

# --- GitHub Models token (github/… models) ---
# A GitHub PAT with the "models" permission — https://github.com/marketplace/models .
# Optional — you can paste it into Settings instead.
GITHUB_MODELS_TOKEN=

# --- Gemini API key (optional; for cli/gemini) ---
# From https://aistudio.google.com/apikey . When set, cli/gemini uses the public
# Gemini API instead of the Gemini CLI's own login. You can paste it into Settings too.
GEMINI_API_KEY=

# --- Jules API key (optional; for cli/jules) ---
# From https://jules.google → Settings. cli/jules is an async agent that works on a
# connected GitHub repo and opens a pull request (it does NOT edit local files).
# Optionally pin a source with JULES_SOURCE=sources/github-<owner>-<repo>.
JULES_API_KEY=
